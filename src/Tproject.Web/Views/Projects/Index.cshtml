@model IReadOnlyList<Tproject.Domain.Entities.Project>
@{
    ViewData["Title"] = "Projects";
    var showCreateForm = ViewBag.ShowCreateForm as bool? ?? false;
}

<div class="page-header">
    <h1>Projects</h1>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Create Project</h5>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label" for="Name">Name</label>
                <input type="text" class="form-control" id="Name" name="Name" required maxlength="200" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="Description">Description</label>
                <textarea class="form-control" id="Description" name="Description" rows="2" maxlength="1000"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Create Project</button>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <p class="text-muted">No projects yet. Create one above to get started.</p>
}
else
{
    <div class="row g-3">
        @foreach (var project in Model)
        {
            <div class="col-md-4">
                <div class="card project-card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@project.Id">@project.Name</a>
                        </h5>
                        @if (!string.IsNullOrWhiteSpace(project.Description))
                        {
                            <p class="card-text text-muted">@project.Description</p>
                        }
                        <small class="text-muted">Created @project.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                </div>
            </div>
        }
    </div>
}
